# Paste your API keys (do not commit real keys to git)
#
# AI toggle: omit or leave empty = AI chat is ON only when ANTHROPIC_API_KEY is set (no terminal prompts).
# Set to false to disable AI temporarily while keeping keys in the file.
# Set to true to force-enable when you use explicit overrides (see backend/ai_settings.py).
THEBOSS_AI_ENABLED=
#
# AI API Keys — Anthropic is required for chat when AI is enabled. OpenAI is used for embeddings (e.g. reference docs).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
USER_AGENT=Course-Sidekick-v1.0

# Supabase (optional - Canvas scraper / DB features; required for auth)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_public_key_here
# JWT Secret (Project Settings > API in Supabase) - used by backend to verify auth tokens
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Development vs production
ENVIRONMENT=development

# CORS — comma-separated list of allowed frontend origins
# In production, set this to your deployed frontend URL (e.g. https://yourapp.onrender.com)
ALLOWED_ORIGINS=http://localhost:3000
