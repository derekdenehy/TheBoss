# Optional — leave unset to use browser localStorage only (default).
# Easiest: copy `supabase.env.template` → `.env.local` and paste your keys there.
# Supabase: Project Settings → API → Project URL and anon public key.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# --- Boss dashboard chat (server-only; never NEXT_PUBLIC_) ---
# Set one or both. If both are set, Claude is used unless BOSS_AI_PROVIDER=openai.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# BOSS_AI_PROVIDER=anthropic
# BOSS_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# BOSS_OPENAI_MODEL=gpt-4o-mini
